---
import type { HourlyPrice } from '../lib/types';
import { formatDateShort } from '../lib/format';
import CurrentPrice from '../islands/CurrentPrice';

interface Props {
  hourly: HourlyPrice[];
  fallbackCurrent: HourlyPrice;
  date: string;
}

const { hourly, fallbackCurrent, date } = Astro.props;
const dateShort = formatDateShort(date);
---

<CurrentPrice client:load hourly={hourly} fallbackCurrent={fallbackCurrent} dateShort={dateShort} />
