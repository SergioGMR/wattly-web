---
import type { Highlights } from '../lib/types';
import { formatPrice, formatHour } from '../lib/format';

interface Props {
  highlights: Highlights;
}

const { highlights } = Astro.props;

const colorTextMap = {
  green: 'text-price-green',
  orange: 'text-price-orange',
  red: 'text-price-red',
};

const cards = [
  {
    label: 'Mínimo del día',
    icon: '↓',
    price: highlights.min,
  },
  {
    label: 'Máximo del día',
    icon: '↑',
    price: highlights.max,
  },
  {
    label: 'Promedio del día',
    icon: '~',
    price: {
      price: highlights.average,
      hour: '',
      color: 'orange' as const,
    },
    isAverage: true,
  },
];
---

<section aria-label="Resumen de precios del día">
  <h2 class="mb-4 text-xs font-semibold tracking-widest text-blue-500 uppercase dark:text-blue-400">
    Resumen del día
  </h2>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
    {
      cards.map(({ label, icon, price, isAverage }) => (
        <div class="glass-card p-4">
          <p class="text-xs font-medium tracking-widest text-slate-600 uppercase dark:text-slate-400">
            <span aria-hidden="true">{icon}</span> {label}
          </p>
          <p class={`mt-2 text-2xl font-bold tabular-nums ${colorTextMap[price.color]}`}>
            {formatPrice(price.price)}
          </p>
          {!isAverage && price.hour && (
            <p class="mt-1 text-xs text-gray-500 dark:text-slate-400">
              a las {formatHour(price.hour)}h
            </p>
          )}
        </div>
      ))
    }
  </div>
</section>
